<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OutputType>Exe</OutputType>
    <GenerateRuntimeConfigurationFiles>true</GenerateRuntimeConfigurationFiles>
    <!-- Tells Lambda tooling which type bootstraps the app -->
    <AWSProjectType>Lambda</AWSProjectType>
  </PropertyGroup>

  <ItemGroup>
    <!-- Lambda ASP.NET Core server integration -->
    <PackageReference Include="Amazon.Lambda.AspNetCoreServer.Hosting" Version="1.7.1" />

    <!-- ADO.NET SQL Server (kept from original — no change needed) -->
    <PackageReference Include="Microsoft.Data.SqlClient" Version="5.2.1" />

    <!-- Standard ASP.NET Core logging (replaces ILoggerFactory-from-DI Azure pattern) -->
    <!-- Already included transitively via the Web SDK, listed here for clarity -->
    <PackageReference Include="Microsoft.Extensions.Logging" Version="8.0.0" />
  </ItemGroup>

</Project>
